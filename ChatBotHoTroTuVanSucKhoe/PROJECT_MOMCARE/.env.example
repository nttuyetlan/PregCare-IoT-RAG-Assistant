# ============================================
# MẦM NHỎ - Edge AI Obstetric Assistant
# Environment Variables Template
# ============================================

# --- Model Paths (relative to project root) ---
QWEN_1_5B_MODEL_PATH=models/qwen2.5-1.5b
QWEN_7B_MODEL_PATH=models/qwen2.5-7b-instruct
WHISPER_MODEL_PATH=models/faster-whisper-small
PIPER_MODEL_PATH=models/piper-vi
SBERT_MODEL_PATH=models/vietnamese-sbert

# --- Database ---
VECTOR_DB_PATH=vector_db
DATA_JSONL_PATH=data/thai_ky_data.jsonl

# --- Server ---
VOICE_PIPELINE_PORT=8000

# --- Voice Pipeline ---
VAD_SILENCE_TIMEOUT_MS=1800
WHISPER_COMPUTE_TYPE=int8
WHISPER_NUM_THREADS=4

# --- Audio Hardware (Orange Pi 5 / es8388) ---
# Chạy "python scripts/check_audio.py" để tìm Index chính xác
# -1 = dùng thiết bị mặc định của hệ thống
AUDIO_INPUT_DEVICE_INDEX=2
AUDIO_OUTPUT_DEVICE_INDEX=2
AUDIO_STT_SAMPLE_RATE=16000
AUDIO_SILENCE_TIMEOUT=2.5
AUDIO_SILENCE_THRESHOLD=500

# --- RAG ---
CHROMA_COLLECTION_NAME=thai_ky_knowledge
TOP_K_RESULTS=3
MEMORY_WINDOW_SIZE=3

# --- Logging ---
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_ROTATION=10 MB

# YouTube API Key cho tinh nang mo nhac
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# Firebase Realtime Database
FIREBASE_DB_URL=https://YOUR_PROJECT_ID-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_DEVICE_ID=demo_device_001
FIREBASE_SECRET=YOUR_FIREBASE_SECRET_HERE